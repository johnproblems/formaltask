{
  "name": "ccpm-vscode-extension",
  "displayName": "CCPM - Context-Centric Project Manager",
  "description": "VSCode extension for Context-Centric Project Management with AI-powered workflow automation",
  "version": "0.1.0",
  "author": "johnproblems (https://github.com/johnproblems)",
  "publisher": "formaltask",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnproblems/formaltask.git"
  },
  "bugs": {
    "url": "https://github.com/johnproblems/formaltask/issues"
  },
  "homepage": "https://github.com/johnproblems/formaltask#readme",
  "keywords": [
    "vscode",
    "extension",
    "project-management",
    "ai",
    "claude",
    "workflow",
    "automation",
    "task-management",
    "ccpm",
    "epic",
    "task-tracking"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "workspaceContains:.claude/epics"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ccpm.showEpicStatus",
        "title": "CCPM: Show Epic Status",
        "icon": "$(graph)"
      },
      {
        "command": "ccpm.addTask",
        "title": "CCPM: Add Task",
        "icon": "$(add)"
      },
      {
        "command": "ccpm.startNext",
        "title": "CCPM: Start Next Task",
        "icon": "$(play)"
      },
      {
        "command": "ccpm.completeCurrent",
        "title": "CCPM: Complete Current Task",
        "icon": "$(check)"
      },
      {
        "command": "ccpm.syncProgress",
        "title": "CCPM: Sync Progress",
        "icon": "$(sync)"
      },
      {
        "command": "ccpm.refreshAll",
        "title": "CCPM: Refresh All",
        "icon": "$(refresh)"
      },
      {
        "command": "ccpm.viewOnGitHub",
        "title": "CCPM: View on GitHub",
        "icon": "$(github)"
      },
      {
        "command": "ccpm.copyIssueNumber",
        "title": "CCPM: Copy Issue Number",
        "icon": "$(clippy)"
      }
    ],
    "views": {
      "ccpm": [
        {
          "id": "ccpmEpics",
          "name": "Epics & Tasks",
          "icon": "$(tasklist)",
          "contextualTitle": "CCPM Epics"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ccpm",
          "title": "CCPM",
          "icon": "resources/ccpm-icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ccpm.refreshAll",
          "when": "view == ccpmEpics",
          "group": "navigation"
        },
        {
          "command": "ccpm.addTask",
          "when": "view == ccpmEpics",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ccpm.startNext",
          "when": "view == ccpmEpics && viewItem == task",
          "group": "1_actions@1"
        },
        {
          "command": "ccpm.completeCurrent",
          "when": "view == ccpmEpics && viewItem == task",
          "group": "1_actions@2"
        },
        {
          "command": "ccpm.syncProgress",
          "when": "view == ccpmEpics && viewItem == task",
          "group": "1_actions@3"
        },
        {
          "command": "ccpm.viewOnGitHub",
          "when": "view == ccpmEpics && viewItem =~ /^(epic|task)$/",
          "group": "2_navigation@1"
        },
        {
          "command": "ccpm.copyIssueNumber",
          "when": "view == ccpmEpics && viewItem == task",
          "group": "2_navigation@2"
        },
        {
          "command": "ccpm.showEpicStatus",
          "when": "view == ccpmEpics && viewItem == epic",
          "group": "1_actions@1"
        },
        {
          "command": "ccpm.refreshAll",
          "when": "view == ccpmEpics",
          "group": "3_refresh@1"
        }
      ],
      "commandPalette": [
        {
          "command": "ccpm.showEpicStatus",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "ccpm.addTask",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "ccpm.startNext",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "ccpm.completeCurrent",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "ccpm.syncProgress",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "ccpm.refreshAll",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "ccpm.viewOnGitHub",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "ccpm.copyIssueNumber",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ccpm.showEpicStatus",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "ccpm.syncProgress",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "ccpm.refreshAll",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "workspaceFolderCount > 0"
      }
    ],
    "configuration": {
      "title": "CCPM",
      "properties": {
        "ccpm.autoRefreshInterval": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "maximum": 3600,
          "description": "Auto-refresh interval in seconds. Set to 0 to disable auto-refresh."
        },
        "ccpm.showProgressPercentage": {
          "type": "boolean",
          "default": true,
          "description": "Show progress percentage in the tree view."
        },
        "ccpm.notifyOnTaskComplete": {
          "type": "boolean",
          "default": true,
          "description": "Show notification when a task is completed."
        },
        "ccpm.notifyOnUnblock": {
          "type": "boolean",
          "default": true,
          "description": "Show notification when a task is unblocked."
        },
        "ccpm.treeViewSortBy": {
          "type": "string",
          "enum": [
            "status",
            "number",
            "priority"
          ],
          "default": "number",
          "description": "Sort order for tasks in the tree view."
        },
        "ccpm.groupCompletedTasks": {
          "type": "boolean",
          "default": true,
          "description": "Group completed tasks at the bottom of the tree view."
        },
        "ccpm.enableStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show CCPM status bar item."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:coverage": "nyc node ./out/test/runTest.js",
    "test:watch": "npm run compile-tests -- -w",
    "coverage": "npm run test:coverage",
    "coverage:report": "nyc report --reporter=html --reporter=text",
    "coverage:check": "nyc check-coverage --lines 0 --functions 0 --branches 0 --statements 0",
    "ci": "npm run lint && npm run compile && npm run pretest && npm run test:coverage && npm run coverage:check",
    "ci:build": "npm run compile && npm run package"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.x",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.56.0",
    "glob": "^13.0.0",
    "mocha": "^11.7.5",
    "nyc": "^17.1.0",
    "sinon": "^21.0.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
