# Project-specific directories (should never be committed)
.claude/epics/*
.claude/prds/*
!.claude/epics/.gitkeep
!.claude/prds/.gitkeep

# VSCode extension build artifacts
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/*.vsix

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/

# Temp files
*.tmp
*.log
